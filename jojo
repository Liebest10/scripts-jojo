local function UpdateNPCs()
    for _, v in pairs(ListScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local t = {"MAIS PRÓXIMO"}; local live = workspace:FindFirstChild("Live")
    if live then 
        for _, m in pairs(live:GetChildren()) do 
            local h = m:FindFirstChildOfClass("Humanoid") 
            if h and h.DisplayName ~= "" and m.Name:sub(1, 8) ~= ".Hostage" and not table.find(t, h.DisplayName) then 
                table.insert(t, h.DisplayName) 
            end 
        end 
    end
    for _, name in pairs(t) do
        local b = Instance.new("TextButton", ListScroll); b.Size = UDim2.new(1,0,0,30); b.BackgroundTransparency = 1; b.Text = name; b.TextColor3 = Color3.fromRGB(255,255,255); b.Font = Enum.Font.GothamBold; b.TextSize = 12; b.MouseButton1Click:Connect(function()
            Config.selectedTarget = name; DropBtn.Text = "ALVO: " .. name; SaveConfig(); ListScroll.Size = UDim2.new(1,0,0,0) 
        end)
    end
end
task.spawn(function() while task.wait(5) do UpdateNPCs() end end)

-- ### FUNÇÕES DE CRIAÇÃO DE COMPONENTES ###
local function CreateToggle(name, configKey)
    local T = Instance.new("TextButton", Content); T.Size = UDim2.new(1,0,0,38); T.BackgroundColor3 = Color3.fromRGB(22,22,25); T.Text = "  "..name; T.Font = Enum.Font.GothamBold; T.TextColor3 = Color3.fromRGB(200,200,200); T.TextSize = 13; T.TextXAlignment = Enum.TextXAlignment.Left; Instance.new("UICorner", T)
    local Box = Instance.new("Frame", T); Box.Size = UDim2.new(0,25,0,12); Box.Position = UDim2.new(1,-35,0.5,-6); Box.BackgroundColor3 = Config[configKey] and Color3.fromRGB(0,170,255) or Color3.fromRGB(60,60,60); Instance.new("UICorner", Box).CornerRadius = UDim.new(1,0)
    T.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]; Box.BackgroundColor3 = Config[configKey] and Color3.fromRGB(0,170,255) or Color3.fromRGB(60,60,60); SaveConfig()
    end)
end

local function CreateSlider(name, min, max, configKey)
    local S = Instance.new("Frame", Content); S.Size = UDim2.new(1,0,0,48); S.BackgroundTransparency = 1
    local T = Instance.new("TextLabel", S); T.Text = name..": "..Config[configKey]; T.Size = UDim2.new(1,0,0,20); T.TextColor3 = Color3.fromRGB(200,200,200); T.Font = Enum.Font.GothamBold; T.TextSize = 12; T.BackgroundTransparency = 1; T.TextXAlignment = Enum.TextXAlignment.Left
    local B = Instance.new("Frame", S); B.Size = UDim2.new(1,0,0,4); B.Position = UDim2.new(0,0,0,32); B.BackgroundColor3 = Color3.fromRGB(40,40,40); local F = Instance.new("Frame", B); F.Size = UDim2.new((Config[configKey]-min)/(max-min), 0, 1, 0); F.BackgroundColor3 = Color3.fromRGB(0,170,255)
    B.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local m = UserInputService.InputChanged:Connect(function(i2) if i2.UserInputType == Enum.UserInputType.MouseMovement then
        local p = math.clamp((i2.Position.X - B.AbsolutePosition.X)/B.AbsoluteSize.X, 0, 1); local v = math.floor(min + (max-min)*p); Config[configKey] = v; F.Size = UDim2.new(p,0,1,0); T.Text = name..": "..v; SaveConfig()
    end end) i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then m:Disconnect() end end) end end)
end

