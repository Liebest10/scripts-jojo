-- ### FUNÇÃO DE CLIQUE PARA INTERFACE ###
local function forceClick(object)
    if object and object.AbsolutePosition then
        local x = object.AbsolutePosition.X + (object.AbsoluteSize.X / 2)
        local y = object.AbsolutePosition.Y + (object.AbsoluteSize.Y / 2) + 58 
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end
end

-- ### LÓGICA DO AUTO FARM & DETECÇÃO DE ALVO ###
task.spawn(function()
    while true do
        CurrentTarget = nil
        if Config.autoFarmEnabled or Config.autoConjuration then
            local target, dist = nil, math.huge
            local live = workspace:FindFirstChild("Live")
            
            if live and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                for _, m in pairs(live:GetChildren()) do
                    -- Prioridade 1: Clone do jogador
                    if Config.autoConjuration and m.Name:find(player.Name) and m.Name:lower():find("clone") then
                        local hum = m:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then target = m; break end
                    end
                    -- Prioridade 2: NPC selecionado ou Mais Próximo
                    if not target and Config.autoFarmEnabled then
                        if m.Name ~= "Server" and m.Name:sub(1, 8) ~= ".Hostage" and m:FindFirstChild("Head") and not Players:GetPlayerFromCharacter(m) then
                            local hum = m:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                if Config.selectedTarget == "MAIS PRÓXIMO" or hum.DisplayName == Config.selectedTarget then
                                    local d = (player.Character.HumanoidRootPart.Position - m.Head.Position).Magnitude
                                    if d < dist then dist = d; target = m end
                                end
                            end
                        end
                    end
                end
            end
            
            if target then
                CurrentTarget = target
                player.Character.HumanoidRootPart.CFrame = CFrame.new(target.Head.Position + Vector3.new(0, Config.farmDistance, 0)) * CFrame.Angles(math.rad(-90), 0, 0)
            end
        end
        RunService.Heartbeat:Wait()
    end
end)

-- ### AUTO SKILLS INTELIGENTE (SÓ BATE NO ALVO) ###
task.spawn(function()
    local skills = {Enum.KeyCode.E, Enum.KeyCode.R, Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.V}
    while true do
        if Config.autoSkillsEnabled and CurrentTarget and CurrentTarget:FindFirstChild("Head") then
            local d = (player.Character.HumanoidRootPart.Position - CurrentTarget.Head.Position).Magnitude
            if d < 25 then
                for _, key in pairs(skills) do
                    if not Config.autoSkillsEnabled or not CurrentTarget then break end
                    VirtualInputManager:SendKeyEvent(true, key, false, game)
                    task.wait(0.01)
                    VirtualInputManager:SendKeyEvent(false, key, false, game)
                    task.wait(0.05)
                end
            end
        end
        task.wait(0.3)
    end
end)

-- ### AUTO CLICK/HOLD INTELIGENTE (SEM LAG NO VAZIO) ###
task.spawn(function()
    local isHolding = false
    while true do
        local canHit = false
        if Config.autoClickHold and CurrentTarget and CurrentTarget:FindFirstChild("Head") then
            local d = (player.Character.HumanoidRootPart.Position - CurrentTarget.Head.Position).Magnitude
            if d < 25 then canHit = true end
        end

        if canHit then
            isHolding = true
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(3)
        else
            if isHolding then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                isHolding = false
            end
            task.wait(0.5)
        end
    end
end)

-- ### AUTO CONJURATION (REPETITIVO) ###
task.spawn(function()
    while true do
        if Config.autoConjuration then
            local cloneExiste = false
            local live = workspace:FindFirstChild("Live")
            if live then
                for _, m in pairs(live:GetChildren()) do
                    if m.Name:find(player.Name) and m.Name:lower():find("clone") then cloneExiste = true; break end
                end
            end

            if not cloneExiste then
                pcall(function()
                    -- Meditação
                    local med = workspace.Map.Meditation:GetChildren()[2]
                    if med and player.Character then
                        player.Character.HumanoidRootPart.CFrame = med.CFrame
                        task.wait(0.4)
                        fireproximityprompt(med:FindFirstChildOfClass("ProximityPrompt"))
                    end
                    task.wait(0.8)
                    -- The Self
                    local theSelf = workspace.Npcs:FindFirstChild("The Self")
                    if theSelf and player.Character then
                        player.Character.HumanoidRootPart.CFrame = theSelf:GetModelCFrame()
                        task.wait(0.4)
                        local prox = theSelf:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if prox then 
                            fireproximityprompt(prox)
                            task.wait(0.5)
                            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                            task.wait(0.05)
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                        end
                    end
                end)
            end
        end
        task.wait(1.5)
    end
end)

